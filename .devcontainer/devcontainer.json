{
  "name": "AI Maturity Ladder",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "AI Maturity Ladder app", "onAutoForward": "openPreview" }
  },
  "containerEnv": {
    "HOST": "0.0.0.0",
    "AIML_MODEL": "claude-opus-4-8"
  },
  "secrets": {
    "ANTHROPIC_API_KEY": {
      "description": "Anthropic API key — required for all five form factors.",
      "documentationUrl": "https://console.anthropic.com/settings/keys"
    },
    "LANGSMITH_API_KEY": {
      "description": "Optional — only used by the evaluation notebook (LangSmith experiments)."
    }
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "postStartCommand": "bash .devcontainer/start-app.sh",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter"]
    }
  }
}
