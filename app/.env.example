# Copy to .env (or rely on the workshop's existing ../.env / ../../.env).
# Only ANTHROPIC_API_KEY is required.

ANTHROPIC_API_KEY=sk-ant-...

# Model used across all five form factors.
AIML_MODEL=claude-opus-4-8
AIML_MAX_TOKENS=1024

# Embedding model (torch-free, via fastembed). Matches the notebook.
AIML_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# Oracle AI Database (optional). If unset/unreachable, RAG uses an in-memory
# NumPy index instead — the app still runs fully. Set ORACLE_ENABLED=0 to skip
# the connection attempt entirely.
ORACLE_ENABLED=1
ORACLE_USER=VECTOR
ORACLE_PASSWORD=VectorPwd_2025
ORACLE_DSN=localhost:1521/FREEPDB1
